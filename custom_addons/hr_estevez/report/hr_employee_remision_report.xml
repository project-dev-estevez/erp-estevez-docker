<odoo>
    <record id="paperformat_hr_employee_remision_full_page" model="report.paperformat">
        <field name="name">HR Employee Remision Full Page</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_hr_employee_remision" model="ir.actions.report">
        <field name="name">Oficio de Remisión</field>
        <field name="model">hr.employee</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_estevez.report_hr_employee_remision</field>
        <field name="print_report_name">(object.name or 'Employee') + ' - Oficio de Remisión'</field>
        <field name="paperformat_id" ref="hr_estevez.paperformat_hr_employee_remision_full_page"/>
    </record>
</odoo>
<odoo>
    <record id="paperformat_hr_contract_addendum_full_page" model="report.paperformat">
        <field name="name">HR Contract Addendum Full Page</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_hr_contract_addendum" model="ir.actions.report">
        <field name="name">Contract Addendum</field>
        <field name="model">hr.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_estevez.report_hr_contract_addendum</field>
        <field name="print_report_name">(object.name or 'Contract') + ' - Addendum'</field>
        <field name="paperformat_id" ref="hr_estevez.paperformat_hr_contract_addendum_full_page"/>
    </record>
</odoo>